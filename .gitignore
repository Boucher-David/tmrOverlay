# Repo-local app data when development overrides are enabled.
# Raw/imported captures can be multi-GB and must stay out of git.
/captures/
/logs/
/diagnostics/
/settings/
/runtime-state.json
/history/user/
/artifacts/

# Local PSD/livery experiments can be large binary files.
/livery-poc/

# Convenience launcher for the ignored macOS harness.
/run.sh

# macOS development harness. Track source/config/tests so UI parity changes are visible,
# but keep generated builds, local app data, captures, and temporary launchers out of git.
local-mac/**/.build/
local-mac/**/.swiftpm/
/local-mac/*/captures/
/local-mac/*/diagnostics/
/local-mac/*/history/
/local-mac/*/logs/
/local-mac/*/settings/
/local-mac/*/artifacts/
/local-mac/*/runtime-state.json
local-mac/**/*.app/
local-mac/**/*.log
