{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://techmatesracing.local/tmr-overlay-contract.schema.json",
  "title": "TMR Overlay Shared Contract",
  "type": "object",
  "additionalProperties": true,
  "required": ["contractVersion", "settings", "design"],
  "properties": {
    "contractVersion": {
      "type": "integer",
      "minimum": 1
    },
    "settings": {
      "type": "object",
      "additionalProperties": true,
      "required": ["settingsVersion", "general", "overlays"],
      "properties": {
        "settingsVersion": {
          "type": "integer",
          "minimum": 1
        },
        "general": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "fontFamily": {
              "type": "string",
              "minLength": 1
            },
            "unitSystem": {
              "enum": ["Metric", "Imperial"]
            }
          }
        },
        "overlays": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "options": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        },
        "optionKeys": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": true,
      "required": ["v2"],
      "properties": {
        "v2": {
          "type": "object",
          "additionalProperties": true,
          "required": ["colors"],
          "properties": {
            "colors": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
              }
            }
          }
        }
      }
    }
  }
}
