{
  "TelemetryCapture": {
    "RawCaptureEnabled": false,
    "StoreSessionInfoSnapshots": true,
    "QueueCapacity": 2048
  },
  "TelemetryEdgeCases": {
    "Enabled": true,
    "PreTriggerSeconds": 10,
    "PostTriggerSeconds": 5,
    "MaxClipsPerSession": 20,
    "MaxFramesPerClip": 240,
    "MinimumFrameSpacingSeconds": 0.1
  },
  "SessionHistory": {
    "Enabled": true,
    "UseBaselineHistory": false
  },
  "Storage": {
    "UseRepositoryLocalStorage": false
  },
  "Logging": {
    "File": {
      "Enabled": true,
      "MinimumLevel": "Information",
      "MaxFileBytes": 2097152,
      "RetainedFileCount": 10
    }
  },
  "Retention": {
    "Enabled": true,
    "CaptureRetentionDays": 30,
    "MaxCaptureDirectories": 50,
    "DiagnosticsRetentionDays": 14,
    "MaxDiagnosticsBundles": 20,
    "PerformanceLogRetentionDays": 30,
    "MaxPerformanceLogFiles": 30,
    "EdgeCaseRetentionDays": 30,
    "MaxEdgeCaseFiles": 50
  },
  "Replay": {
    "Enabled": false,
    "CaptureDirectory": "",
    "SpeedMultiplier": 1.0
  },
  "OverlayBridge": {
    "Enabled": false,
    "Port": 8765
  }
}
