{
  "TelemetryCapture": {
    "RawCaptureEnabled": true,
    "StoreSessionInfoSnapshots": true,
    "QueueCapacity": 2048,
    "MaxSynthesisMilliseconds": 60000
  },
  "TelemetryEdgeCases": {
    "Enabled": true,
    "PreTriggerSeconds": 10,
    "PostTriggerSeconds": 5,
    "MaxClipsPerSession": 20,
    "MaxFramesPerClip": 240,
    "MinimumFrameSpacingSeconds": 0.1
  },
  "LiveModelParity": {
    "Enabled": true,
    "MinimumFrameSpacingSeconds": 1.0,
    "MaxFramesPerSession": 600,
    "MaxObservationsPerFrame": 20,
    "MaxObservationSummaries": 200,
    "PromotionCandidateMinimumFrames": 10000,
    "PromotionCandidateMaxMismatchFrameRate": 0.001,
    "PromotionCandidateMinimumCoverageRatio": 0.98,
    "OutputFileName": "live-model-parity.json",
    "LogDirectoryName": "model-parity"
  },
  "LiveOverlayDiagnostics": {
    "Enabled": true,
    "MinimumFrameSpacingSeconds": 1.0,
    "MaxSampleFramesPerSession": 240,
    "MaxEventExamplesPerSession": 80,
    "MaxEventExamplesPerKind": 8,
    "LargeGapSeconds": 600,
    "LargeGapLapEquivalent": 1.0,
    "GapJumpSeconds": 300,
    "OutputFileName": "live-overlay-diagnostics.json",
    "LogDirectoryName": "overlay-diagnostics"
  },
  "IbtAnalysis": {
    "Enabled": true,
    "TelemetryLoggingEnabled": true,
    "TelemetryRoot": "",
    "MaxCandidateAgeMinutes": 1440,
    "MaxCandidateBytes": 17179869184,
    "MaxAnalysisMilliseconds": 60000,
    "MaxSampledRecords": 20000,
    "MinStableAgeSeconds": 5,
    "MaxIRacingExitWaitSeconds": 60,
    "MaxCandidateFiles": 200,
    "CopyIbtIntoCaptureDirectory": false,
    "OutputDirectoryName": "ibt-analysis"
  },
  "SessionHistory": {
    "Enabled": true,
    "UseBaselineHistory": false
  },
  "PostRaceAnalysis": {
    "Enabled": true
  },
  "Storage": {
    "UseRepositoryLocalStorage": false
  },
  "Logging": {
    "File": {
      "Enabled": true,
      "MinimumLevel": "Debug",
      "MaxFileBytes": 10485760,
      "RetainedFileCount": 20
    }
  },
  "Retention": {
    "Enabled": true,
    "CaptureRetentionDays": 30,
    "MaxCaptureDirectories": 50,
    "DiagnosticsRetentionDays": 14,
    "MaxDiagnosticsBundles": 20,
    "PerformanceLogRetentionDays": 30,
    "MaxPerformanceLogFiles": 30,
    "EdgeCaseRetentionDays": 30,
    "MaxEdgeCaseFiles": 50
  },
  "Replay": {
    "Enabled": false,
    "CaptureDirectory": "",
    "SpeedMultiplier": 1.0
  },
  "LocalhostOverlays": {
    "Enabled": true,
    "Port": 8765
  },
  "Updates": {
    "Enabled": true,
    "CheckOnStartup": true,
    "RepositoryUrl": "https://github.com/Boucher-David/TMROverlay",
    "IncludePrerelease": false,
    "StartupDelaySeconds": 8
  }
}
